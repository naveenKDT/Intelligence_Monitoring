{
  "name": "b2b-company-scraper",
  "version": "1.0.0",
  "description": "Automated B2B company web scraper with Playwright, PostgreSQL, and pgvector embeddings",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "scrape": "npm run build && node dist/index.js",
    "dev": "ts-node src/index.ts",
    "setup-db": "docker-compose up -d postgres && sleep 5 && node dist/database/schema.js"
  },
  "keywords": [
    "scraper",
    "playwright",
    "postgresql",
    "pgvector",
    "company-data",
    "b2b"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.7",
    "chalk": "^4.1.2",
    "cheerio": "^1.0.0-rc.12",
    "cli-progress": "^3.12.0",
    "dotenv": "^16.4.5",
    "levenshtein": "^1.0.5",
    "lodash": "^4.17.21",
    "openai": "^4.28.0",
    "pg": "^8.11.3",
    "playwright": "^1.41.2"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/cli-progress": "^3.11.5",
    "@types/levenshtein": "^1.0.4",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.11.19",
    "@types/pg": "^8.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
